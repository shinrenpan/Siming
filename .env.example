# Siming FHIR R4 Server — environment variable template
# Copy this file to .env and fill in your values.
# .env is git-ignored; never commit secrets.
#
# Environment variables override the corresponding config.yml fields.

# ── Database ──────────────────────────────────────────────────────────────────

# Postgres credentials (must match what your DB server expects)
PGUSER=siming
PGPASSWORD=siming
PGDATABASE=siming

# Alternative: single connection URL (takes priority over PG* vars)
# DATABASE_URL=postgres://siming:siming@db:5432/siming

# ── Server ────────────────────────────────────────────────────────────────────

# Public base URL — set this when running behind a reverse proxy
# SERVER_BASE_URL=https://fhir.example.com

# TCP port exposed on the host
# SERVER_PORT=8080

# ── External validator ────────────────────────────────────────────────────────

# Uncomment to enable deep TW Core profile validation via HL7 FHIR Validator.
# Also uncomment the `validator` service block in docker-compose.yml.
# VALIDATOR_URL=http://validator:4567

# ── SMART on FHIR (optional) ──────────────────────────────────────────────────

# Set SMART_ISSUER to enable JWT bearer authentication.
# SMART_ISSUER=https://auth.example.com
# SMART_JWKS_URL=https://auth.example.com/.well-known/jwks.json
# SMART_PUBLIC_KEY_PEM=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# SMART_AUDIENCE=https://fhir.example.com

# ── Rate limiting (optional) ──────────────────────────────────────────────────

# RATE_LIMIT_RPS=100
# RATE_LIMIT_BURST=200

# ── Logging ───────────────────────────────────────────────────────────────────

# LOG_LEVEL=info
